{
  "name": "mowmow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run generate:svg",
    "generate:svg": "tsc -p tsconfig.scripts.json && esbuild scripts/generateSvg.ts --bundle --platform=node --format=esm --outfile=.generated-scripts/generateSvg.mjs && node .generated-scripts/generateSvg.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.18.2"
  }
}
