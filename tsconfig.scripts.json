{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.scripts.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "scripts/**/*.ts",
    "src/data/**/*.ts",
    "src/github/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts",
    "src/renderers/**/*.ts"
  ]
}
